        <object placeholders="1" c4Name="Composable Channel Platform" c4Type="Software System" c4Description="Multi-channel composition layer: web and mobile shells (SDUI), BFF orchestration, profile context management, auth integration (ForgeRock + OPA), MFE hosting via Module Federation, and developer portal. Domain teams plug in their journeys as MFEs." label="&lt;font style=&quot;font-size: 16px&quot;&gt;&lt;b&gt;%c4Name%&lt;/b&gt;&lt;/font&gt;&lt;div&gt;[%c4Type%]&lt;/div&gt;&lt;br&gt;&lt;div&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;%c4Description%&lt;/font&gt;&lt;/div&gt;" id="sys-platform">
