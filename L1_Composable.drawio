        <object placeholders="1" c4Name="ForgeRock / PingOne AIC" c4Type="Software System" c4Description="OIDC identity provider with integrated OPA authorization. Authentication, MFA, step-up auth, Journey orchestration, PingOne Protect risk scoring. Uses OPA as the authz decision layer within auth flows." label="&lt;font style=&quot;font-size: 16px&quot;&gt;&lt;b&gt;%c4Name%&lt;/b&gt;&lt;/font&gt;&lt;div&gt;[%c4Type%]&lt;/div&gt;&lt;br&gt;&lt;div&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;%c4Description%&lt;/font&gt;&lt;/div&gt;" id="ext-forgerock">
